# secaudit-gui Justfile — GUI 命令

GUI_DIR := "."
GUI_TAURI_MANIFEST := "./src-tauri/Cargo.toml"
GUI_CLEAN_OUTPUTS := "dist,test-results"
GUI_NODE_MODULES := "node_modules"

_default:
    @just --list

install:
    bun ci

# 清理 GUI 前端构建与测试产物
clean-frontend:
    bun --eval "import { rmSync } from 'node:fs'; for (const path of '{{ GUI_CLEAN_OUTPUTS }}'.split(',')) rmSync(path, { recursive: true, force: true });"

# 清理 GUI Tauri Rust 构建产物
clean-tauri:
    cargo clean --manifest-path {{ GUI_TAURI_MANIFEST }}

# 清理 GUI 构建产物
clean: clean-frontend clean-tauri

# 深度清理 GUI 依赖目录
clean-deps: clean
    bun --eval "import { rmSync } from 'node:fs'; rmSync('{{ GUI_NODE_MODULES }}', { recursive: true, force: true });"

# GUI 前端与 Tauri 后端质量检查
check:
    bun run --cwd {{ GUI_DIR }} check
    cargo fmt --manifest-path {{ GUI_TAURI_MANIFEST }} --check
    cargo clippy --manifest-path {{ GUI_TAURI_MANIFEST }} --all-targets -- -D warnings
    cargo test --manifest-path {{ GUI_TAURI_MANIFEST }} --all-targets

# 生成 GUI 的 Rust -> TypeScript 绑定
bindings:
    cargo test --manifest-path {{ GUI_TAURI_MANIFEST }} --lib export_bindings

# 构建 GUI 前端产物
build: bindings
    bun run --cwd {{ GUI_DIR }} build

# 运行 GUI 浏览器烟测（Edge/Chrome + CDP）
gui-smoke:
    bun run --cwd {{ GUI_DIR }} smoke:gui

# 启动真实 Tauri GUI 桌面端
dev:
    bun run --cwd {{ GUI_DIR }} tauri dev

# 启动浏览器预览服务（使用 mock 数据，不连接 Tauri 后端）
preview:
    bun run --cwd {{ GUI_DIR }} dev
