      {
        "title": "SecAudit Agent",
        "width": 1280,
        "height": 820,
        "minWidth": 1080,
        "minHeight": 680
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
