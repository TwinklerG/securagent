{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SecAudit Agent",
  "version": "0.1.0",
  "identifier": "dev.secaudit.agent",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
