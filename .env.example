# API 配置
SECAUDIT_API_KEY=your-api-key
SECAUDIT_API_BASE_URL=https://api.openai.com/v1

# 模型配置
SECAUDIT_MODEL=gpt-4o
SECAUDIT_CONTEXT_WINDOW_TOKENS=128000

# 推理策略 (react / reflexion)
SECAUDIT_STRATEGY=react

# 最大 ReAct 循环轮次
SECAUDIT_MAX_ITERATIONS=40

# 命令策略配置（逗号分隔）
# 白名单命令会自动放行；黑名单命令会直接拒绝，黑名单优先级更高
SECAUDIT_COMMAND_ALLOWLIST=
SECAUDIT_COMMAND_BLOCKLIST=

# 敏感路径追加黑名单（逗号分隔）
# 默认敏感路径仍会被保护，这里只用于追加项目特定的敏感目录或文件名
SECAUDIT_SENSITIVE_PATH_BLOCKLIST=

# LLM 调用重试与熔断配置
SECAUDIT_LLM_RETRY_MAX_ATTEMPTS=2
SECAUDIT_LLM_RETRY_INITIAL_DELAY_MS=200
SECAUDIT_LLM_RETRY_MAX_DELAY_MS=2000
SECAUDIT_LLM_CIRCUIT_BREAKER_FAILURE_THRESHOLD=3
SECAUDIT_LLM_CIRCUIT_BREAKER_COOLDOWN_MS=30000
